# ============================================================
# AiOps .gitignore
# ============================================================

# --- 环境变量 (含敏感信息，禁止提交) ---
.env
.env.local
.env.production
.env.*.local

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
*.egg
dist/
build/

# --- 虚拟环境 ---
venv/
.venv/
ENV/
env/

# --- Django ---
db.sqlite3
db.sqlite3-journal
*.log
media/
staticfiles/
local_settings.py

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- OS ---
.DS_Store
Thumbs.db

# --- Jupyter Notebook ---
.ipynb_checkpoints/

# --- Celery ---
celerybeat-schedule
celerybeat.pid

# --- 其他 ---
.coverage
htmlcov/
.pytest_cache/
.mypy_cache/
