# ============================================================
# AiOps 项目环境配置模板 (.env.example)
# 使用方法:  cp .env.example .env   然后填写实际值
# ============================================================

# --- Django 基础配置 ---
DJANGO_SECRET_KEY=your-django-secret-key-here
DJANGO_DEBUG=True
APP_MASTER_KEY=your-fernet-master-key-here

# --- 数据库配置 ---
# DB_ENGINE=postgresql (使用 PostgreSQL) 或留空 (默认 SQLite 开发模式)
DB_ENGINE=
DB_NAME=aiops_db
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# --- Redis 配置 (Celery 消息队列 + WebSocket Channels) ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# --- AI 诊断引擎 (Qwen3 / OpenAI 兼容) ---
#
# [推荐] 阿里云通义千问 Qwen3:
#   获取 Key: https://dashscope.console.aliyun.com/apiKey
QWEN_API_KEY=sk-your-qwen-api-key-here
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# [可选] OpenAI 兼容接口 (OneAPI / DeepSeek / LocalAI 等):
# OPENAI_API_KEY=sk-your-api-key-here
# OPENAI_BASE_URL=https://api.openai.com/v1

# AI 诊断模型选择:
#   qwen-turbo   - 快速响应，适合高频告警
#   qwen-plus    - 推荐，平衡速度与质量 (默认)
#   qwen-max     - 最强推理，适合复杂根因分析
AI_DIAGNOSE_MODEL=qwen-plus
